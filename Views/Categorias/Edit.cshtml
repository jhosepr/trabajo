@model Farmacia.Models.Categoria

@{
    ViewData["Title"] = "Editar Categoría";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border border-warning rounded-4 bg-dark text-light overflow-hidden">
                <div class="card-header bg-warning text-dark py-4 text-center border-bottom border-warning">
                    <i class="fas fa-edit fa-3x mb-2 shadow-sm rounded-circle p-1" style="background: rgba(0,0,0,0.1);"></i>
                    <h3 class="mb-0 fw-bold">Editar Categoría</h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border border-danger text-center rounded-3 p-2 mb-4"></div>
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-4">
                            <label asp-for="Nombre" class="form-label fw-bold text-light opacity-75 text-uppercase small"></label>
                            <input asp-for="Nombre" class="form-control bg-dark border-secondary text-light fw-bold px-3 py-2" placeholder="Ej. Analgésicos" />
                            <span asp-validation-for="Nombre" class="text-danger small mt-1 d-block"></span>
                        </div>
                        
                        <div class="mb-5">
                            <label asp-for="Descripcion" class="form-label fw-bold text-light opacity-75 text-uppercase small"></label>
                            <input asp-for="Descripcion" class="form-control bg-dark border-secondary text-light px-3 py-2" placeholder="Descripción de la categoría" />
                            <span asp-validation-for="Descripcion" class="text-danger small mt-1 d-block"></span>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-bold text-light">
                                <i class="fas fa-arrow-left me-1"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold text-dark shadow-sm">
                                <i class="fas fa-save me-1"></i> Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
<style>
    input.form-control:focus { background-color: #1a1e23; border-color: #ffc107; color: white; box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25); }
</style>
