@model IEnumerable<Farmacia.Models.Categoria>
@{
    ViewData["Title"] = "Categorías de Medicamentos";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-light"><i class="fas fa-tags me-2 p-2 rounded bg-secondary text-white"></i>Categorías</h2>
    @if (User.IsInRole("Administrador"))
    {
        <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4 fw-bold">
            <i class="fas fa-plus me-1"></i> Nueva Categoría
        </a>
    }
</div>

<div class="card shadow-sm border border-secondary rounded-4 bg-dark">
    <div class="card-body p-0 overflow-hidden rounded-4">
        <table class="table table-dark table-striped table-hover mb-0">
            <thead class="table-black">
                <tr>
                    <th class="ps-4 py-3 text-secondary text-uppercase small">@Html.DisplayNameFor(model => model.Nombre)</th>
                    <th class="py-3 text-secondary text-uppercase small">@Html.DisplayNameFor(model => model.Descripcion)</th>
                    <th class="text-center py-3 text-secondary text-uppercase small">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 align-middle fw-bold text-light">@Html.DisplayFor(modelItem => item.Nombre)</td>
                        <td class="align-middle text-light opacity-75">@Html.DisplayFor(modelItem => item.Descripcion)</td>
                        <td class="text-center align-middle">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3">
                                <i class="fas fa-eye"></i> Ver
                            </a>
                            @if (User.IsInRole("Administrador"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning rounded-pill px-3 mx-1">
                                    <i class="fas fa-edit"></i> Editar
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                    <i class="fas fa-trash"></i> Eliminar
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
