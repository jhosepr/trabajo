@model IEnumerable<Farmacia.Models.Medicamento>
@{
    ViewData["Title"] = ViewData["Titulo"];
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Titulo"]</h2>
        <div>
            <button onclick="window.print()" class="btn btn-secondary me-2">
                <i class="fas fa-print"></i> Imprimir
            </button>
            <a asp-action="ExportToExcel" asp-route-tipo="@ViewContext.RouteData.Values["action"]" class="btn btn-success">
                <i class="fas fa-file-excel"></i> Exportar Excel
            </a>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Estante</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Vencimiento</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nombre</td>
                            <td>@item.Categoria?.Nombre</td>
                            <td>@item.Estante?.Nombre</td>
                            <td>@item.Precio.ToString("C")</td>
                            <td>@item.Stock</td>
                            <td>@item.FechaVencimiento.ToShortDateString()</td>
                            <td>
                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-primary">Volver al Centro de Reportes</a>
    </div>
</div>
