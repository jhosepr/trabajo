@{
    ViewData["Title"] = "Centro de Reportes";
}

<div class="container py-4">
    <div class="row mb-5 text-center">
        <div class="col-12">
            <h1 class="display-5 fw-bold text-white"><i class="fas fa-file-invoice me-3 text-primary"></i>Centro de Reportes</h1>
            <p class="lead text-secondary">Genera informes detallados para la gestión del inventario y control de estado.</p>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- Reporte Vencidos -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-lg border border-danger bg-dark rounded-4 transition-hover">
                <div class="card-body text-center p-4">
                    <div class="mb-4 text-danger bg-black rounded-circle d-inline-block p-3 border border-danger">
                        <i class="fas fa-calendar-times fa-3x"></i>
                    </div>
                    <h5 class="card-title text-light fw-bold">Medicamentos Vencidos</h5>
                    <p class="card-text small text-secondary mb-4">Lista de productos cuya fecha de vencimiento ya expiró de acuerdo al sistema.</p>
                    <a asp-action="MedicamentosVencidos" class="btn btn-danger w-100 rounded-pill fw-bold">Ver Reporte</a>
                </div>
            </div>
        </div>

        <!-- Reporte Por Vencer -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-lg border border-warning bg-dark rounded-4 transition-hover">
                <div class="card-body text-center p-4">
                    <div class="mb-4 text-warning bg-black rounded-circle d-inline-block p-3 border border-warning">
                        <i class="fas fa-clock fa-3x"></i>
                    </div>
                    <h5 class="card-title text-light fw-bold">Próximos a Vencer</h5>
                    <p class="card-text small text-secondary mb-4">Productos activos que vencen o expiran en los próximos 30 días.</p>
                    <a asp-action="PorVencer30Dias" class="btn btn-warning w-100 rounded-pill fw-bold text-dark">Ver Reporte</a>
                </div>
            </div>
        </div>

        <!-- Reporte Bajo Stock -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-lg border border-info bg-dark rounded-4 transition-hover">
                <div class="card-body text-center p-4">
                    <div class="mb-4 text-info bg-black rounded-circle d-inline-block p-3 border border-info">
                        <i class="fas fa-layer-group fa-3x"></i>
                    </div>
                    <h5 class="card-title text-light fw-bold">Bajo Stock</h5>
                    <p class="card-text small text-secondary mb-4">Productos con existencias críticas en bodega (≤ 10 unidades registradas).</p>
                    <a asp-action="BajoStock" class="btn btn-info w-100 rounded-pill fw-bold text-dark">Ver Reporte</a>
                </div>
            </div>
        </div>

        <!-- Inventario Completo -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-lg border border-primary bg-dark rounded-4 transition-hover">
                <div class="card-body text-center p-4">
                    <div class="mb-4 text-primary bg-black rounded-circle d-inline-block p-3 border border-primary">
                        <i class="fas fa-file-medical fa-3x"></i>
                    </div>
                    <h5 class="card-title text-light fw-bold">Inventario Total</h5>
                    <p class="card-text small text-secondary mb-4">Listado completo, histórico y actualizado de todos los productos.</p>
                    <a asp-action="InventarioCompleto" class="btn btn-primary w-100 rounded-pill fw-bold">Ver Reporte</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .transition-hover:hover { transform: translateY(-5px); box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.4) !important; }
</style>
