@{
    ViewData["Title"] = "Centro de Reportes";
}

<div class="container py-4">
    <div class="row mb-4 text-center">
        <div class="col-12">
            <h1 class="display-5 fw-bold">📑 Centro de Reportes</h1>
            <p class="lead text-muted">Genera informes detallados para la gestión del inventario.</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Reporte Vencidos -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-danger">
                <div class="card-body text-center">
                    <div class="mb-3 text-danger">
                        <i class="fas fa-calendar-times fa-3x"></i>
                    </div>
                    <h5 class="card-title">Medicamentos Vencidos</h5>
                    <p class="card-text small text-muted">Lista de productos cuya fecha de vencimiento ya expiró.</p>
                    <a asp-action="MedicamentosVencidos" class="btn btn-danger w-100">Ver Reporte</a>
                </div>
            </div>
        </div>

        <!-- Reporte Por Vencer -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-warning">
                <div class="card-body text-center">
                    <div class="mb-3 text-warning">
                        <i class="fas fa-clock fa-3x"></i>
                    </div>
                    <h5 class="card-title">Próximos a Vencer</h5>
                    <p class="card-text small text-muted">Productos que vencen en los próximos 30 días.</p>
                    <a asp-action="PorVencer30Dias" class="btn btn-warning w-100">Ver Reporte</a>
                </div>
            </div>
        </div>

        <!-- Reporte Bajo Stock -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-info">
                <div class="card-body text-center">
                    <div class="mb-3 text-info">
                        <i class="fas fa-layer-group fa-3x"></i>
                    </div>
                    <h5 class="card-title">Bajo Stock</h5>
                    <p class="card-text small text-muted">Productos con existencias críticas (≤ 10 unidades).</p>
                    <a asp-action="BajoStock" class="btn btn-info w-100 text-white">Ver Reporte</a>
                </div>
            </div>
        </div>

        <!-- Inventario Completo -->
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-body text-center">
                    <div class="mb-3 text-primary">
                        <i class="fas fa-file-medical fa-3x"></i>
                    </div>
                    <h5 class="card-title">Inventario Total</h5>
                    <p class="card-text small text-muted">Listado completo de todos los productos registrados.</p>
                    <a asp-action="InventarioCompleto" class="btn btn-primary w-100">Ver Reporte</a>
                </div>
            </div>
        </div>
    </div>
</div>
