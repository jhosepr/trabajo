<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Farmacia</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/practica.styles.css" asp-append-version="true" />
    <!-- Ensure FontAwesome is included for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="bg-dark text-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-black border-bottom border-secondary mb-4 shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-clinic-medical me-2"></i>Farmacia
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="fas fa-tachometer-alt me-1"></i>Dashboard</a>
                            </li>
                            @if (User.IsInRole("Administrador") || User.IsInRole("Farmaceutico"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Categorias" asp-action="Index"><i class="fas fa-tags me-1"></i>Categorías</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Estantes" asp-action="Index"><i class="fas fa-layer-group me-1"></i>Estantes</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Medicamentoes" asp-action="Index"><i class="fas fa-pills me-1"></i>Medicamentos</a>
                            </li>
                            @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Reportes" asp-action="Index"><i class="fas fa-chart-bar me-1"></i>Reportes</a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item me-3">
                                <span class="nav-link text-info fw-semibold"><i class="fas fa-user-circle me-1"></i>@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post">
                                    <button type="submit" class="btn btn-outline-light btn-sm mt-1">Cerrar Sesión</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Auth" asp-action="Login">Iniciar Sesión</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Auth" asp-action="Registro">Registrarse</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - Farmacia
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>