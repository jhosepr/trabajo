@model practica.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard de Gestión";
}

<div class="container-fluid py-4">
    <div class="row mb-5">
        <div class="col-12">
            <h1 class="h3 mb-1 fw-bold text-white"><i class="fas fa-tachometer-alt me-2 text-info"></i>Panel de Control</h1>
            <p class="text-secondary">Resumen operativo para la toma de decisiones.</p>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row">
        <!-- Total Medicamentos -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 shadow h-100 py-2 bg-dark rounded-4" style="border-left: 4px solid #4e73df !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Medicamentos</div>
                            <div class="h4 mb-0 font-weight-bold text-white">@Model.TotalMedicamentos</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-pills fa-2x text-secondary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Vencidos -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 shadow h-100 py-2 bg-dark rounded-4" style="border-left: 4px solid #e74a3b !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Vencidos</div>
                            <div class="h4 mb-0 font-weight-bold text-white">@Model.MedicamentosVencidos</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-calendar-times fa-2x text-secondary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Por Vencer -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 shadow h-100 py-2 bg-dark rounded-4" style="border-left: 4px solid #f6c23e !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Por Vencer (30d)</div>
                            <div class="h4 mb-0 font-weight-bold text-white">@Model.MedicamentosPorVencer</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-exclamation-triangle fa-2x text-secondary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bajo Stock -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 shadow h-100 py-2 bg-dark rounded-4" style="border-left: 4px solid #36b9cc !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Bajo Stock (≤10)</div>
                            <div class="h4 mb-0 font-weight-bold text-white">@Model.ProductosBajoStock</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-boxes fa-2x text-secondary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row mt-2">
        <!-- Bar Chart -->
        <div class="col-xl-8 col-lg-7">
            <div class="card border border-secondary shadow mb-4 bg-dark rounded-4">
                <div class="card-header py-3 bg-black border-bottom border-secondary d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-chart-bar me-2"></i>Distribución por Categoría</h6>
                </div>
                <div class="card-body bg-dark">
                    <div class="chart-area">
                        <canvas id="myBarChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Donut Chart -->
        <div class="col-xl-4 col-lg-5">
            <div class="card border border-secondary shadow mb-4 bg-dark rounded-4">
                <div class="card-header py-3 bg-black border-bottom border-secondary d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-chart-pie me-2"></i>Estado de Inventario</h6>
                </div>
                <div class="card-body bg-dark">
                    <div class="chart-pie pt-4 pb-2">
                        <canvas id="myPieChart"></canvas>
                    </div>
                    <div class="mt-4 text-center small text-light opacity-75">
                        <span class="mr-2">
                            <i class="fas fa-circle text-primary"></i> Normal
                        </span>
                        <span class="mr-2">
                            <i class="fas fa-circle text-danger"></i> Vencido
                        </span>
                        <span class="mr-2">
                            <i class="fas fa-circle text-warning"></i> Por Vencer
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        Chart.defaults.color = '#a0a0a0';
        Chart.defaults.scale.grid.color = 'rgba(255, 255, 255, 0.05)';

        // Pie Chart
        const ctxPie = document.getElementById('myPieChart').getContext('2d');
        new Chart(ctxPie, {
            type: 'doughnut',
            data: {
                labels: ["Normal", "Vencido", "Por Vencer"],
                datasets: [{
                    data: [@(Model.TotalMedicamentos - Model.MedicamentosVencidos - Model.MedicamentosPorVencer), @Model.MedicamentosVencidos, @Model.MedicamentosPorVencer],
                    backgroundColor: ['#4e73df', '#e74a3b', '#f6c23e'],
                    hoverBackgroundColor: ['#2e59d9', '#c10000', '#dda20a'],
                    borderColor: "#1a1e23",
                    borderWidth: 2,
                }],
            },
            options: {
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                cutout: '80%',
            },
        });

        // Bar Chart
        const ctxBar = document.getElementById('myBarChart').getContext('2d');
        new Chart(ctxBar, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.CategoriasNombres)),
                datasets: [{
                    label: "Cant. Productos",
                    backgroundColor: "#4e73df",
                    hoverBackgroundColor: "#2e59d9",
                    borderColor: "#4e73df",
                    data: @Html.Raw(Json.Serialize(Model.CategoriasConteo)),
                }],
            },
            options: {
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    </script>
}

<style>
    /* Premium Dashboard Styles */
    .card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.3) !important;
    }
    
    .card-body { padding: 1.5rem; }
    
    .text-xs {
        font-size: 0.8rem;
        letter-spacing: 0.05em;
    }
    
    .font-weight-bold { font-weight: 700 !important; }
    .chart-area { height: 320px; position: relative }
    .chart-pie { height: 260px; position: relative }
</style>
