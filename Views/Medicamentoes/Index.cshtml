@model IEnumerable<Farmacia.Models.Medicamento>
@{
    ViewData["Title"] = "Catálogo de Medicamentos";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-light"><i class="fas fa-pills me-2 p-2 rounded bg-secondary text-white"></i>Catálogo de Medicamentos</h2>
    @if (User.IsInRole("Administrador") || User.IsInRole("Farmaceutico"))
    {
        <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4 fw-bold">
            <i class="fas fa-plus me-1"></i>Nuevo Medicamento
        </a>
    }
</div>

<!-- Filtros de búsqueda -->
<div class="card bg-secondary bg-opacity-10 border-0 rounded-4 mb-4 shadow-sm">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-5">
                <label class="form-label text-light fw-bold small text-uppercase">Buscar por Nombre:</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-light"><i class="fas fa-search"></i></span>
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control bg-dark text-light border-secondary" placeholder="Ej. Paracetamol..." />
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label text-light fw-bold small text-uppercase">Filtrar por Categoría:</label>
                <select name="categoriaId" class="form-select bg-dark text-light border-secondary" asp-items="ViewBag.Categorias">
                    <option value="">Todas las Categorías</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-info px-4 fw-bold w-100 text-dark"><i class="fas fa-filter me-1"></i> Filtrar</button>
                <a asp-action="Index" class="btn btn-outline-secondary text-light"><i class="fas fa-redo"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 mb-5">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border border-secondary rounded-4 transition-hover bg-dark">
                <div class="card-header border-bottom-0 pt-4 pb-2 bg-transparent">
                    <div class="d-flex justify-content-between align-items-start">
                        <h4 class="card-title fw-bold text-light mb-1">@Html.DisplayFor(modelItem => item.Nombre)</h4>
                        <span class="badge bg-primary text-white fs-6 py-2 px-3 shadow-sm rounded-pill" style="background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);">
                            $@item.Precio
                        </span>
                    </div>
                    <span class="badge bg-secondary text-light border border-secondary mt-2"><i class="fas fa-tag me-1"></i>@(item.Categoria?.Nombre ?? "Sin categoría")</span>
                    @if (!item.Estado)
                    {
                        <span class="badge bg-danger ms-1">Inactivo</span>
                    }
                </div>
                
                <div class="card-body">
                    <p class="card-text text-light opacity-75 mb-4 small" style="min-height: 40px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        @(string.IsNullOrEmpty(item.Descripcion) ? "Sin descripción detallada." : item.Descripcion)
                    </p>
                    
                    <div class="border border-secondary rounded-3 overflow-hidden">
                        <div class="d-flex justify-content-between align-items-center p-3 bg-secondary bg-opacity-25 border-bottom border-secondary">
                            <span class="small fw-bold text-light">Stock Disponible</span>
                            @if (item.BajoStock)
                            {
                                <span class="badge bg-danger rounded-pill px-3 shadow-sm">@item.Stock <i class="fas fa-exclamation-triangle ms-1"></i></span>
                            }
                            else
                            {
                                <span class="badge bg-success rounded-pill px-3 shadow-sm">@item.Stock unids.</span>
                            }
                        </div>
                        <div class="d-flex justify-content-between align-items-center p-3 border-bottom border-secondary bg-transparent">
                            <span class="small fw-bold text-light">Vencimiento</span>
                            @if (item.EstaVencido)
                            {
                                <span class="badge bg-danger px-2"><i class="fas fa-times-circle me-1"></i>@item.FechaVencimiento.ToShortDateString()</span>
                            }
                            else if (item.PorVencer30)
                            {
                                <span class="badge bg-warning text-dark px-2"><i class="fas fa-exclamation-circle me-1"></i>@item.FechaVencimiento.ToShortDateString()</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark px-2">@item.FechaVencimiento.ToShortDateString()</span>
                            }
                        </div>
                        <div class="d-flex justify-content-between align-items-center p-3 bg-secondary bg-opacity-25">
                            <span class="small fw-bold text-light">Estante / Ubicación</span>
                            <span class="small fw-bold text-light">@(item.Estante?.Nombre ?? "N/A")</span>
                        </div>
                    </div>
                </div>
                
                @if (User.IsInRole("Administrador") || User.IsInRole("Farmaceutico"))
                {
                    <div class="card-footer border-top-0 pb-4 pt-1 bg-transparent">
                        <hr class="text-secondary opacity-50 mt-0 mb-3" />
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm rounded-pill px-3 fw-bold" title="Detalles">
                                <i class="fas fa-eye me-1"></i>Detalles
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm rounded-pill px-3 fw-bold" title="Editar">
                                <i class="fas fa-edit"></i>
                            </a>
                            @if (User.IsInRole("Administrador"))
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold" title="Eliminar">
                                    <i class="fas fa-trash"></i>
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-dark border border-secondary shadow-sm rounded-4 text-center p-5 mt-4" role="alert">
        <i class="fas fa-search fa-3x text-secondary mb-3 opacity-50"></i>
        <h4 class="alert-heading fw-bold text-light">No hay medicamentos</h4>
        <p class="mb-0 text-light opacity-75">Actualmente no se encontraron medicamentos que coincidan con la búsqueda.</p>
    </div>
}

<style>
    .transition-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .transition-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.5)!important;
    }
</style>