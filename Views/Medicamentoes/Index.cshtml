@model IEnumerable<Farmacia.Models.Medicamento>
@{
    ViewData["Title"] = "Medicamentos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>💊 Medicamentos</h2>
    @if (User.IsInRole("Administrador") || User.IsInRole("Farmaceutico"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Nuevo Medicamento</a>
    }
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Nombre)</th>
            <th>@Html.DisplayNameFor(model => model.Precio)</th>
            <th>@Html.DisplayNameFor(model => model.Stock)</th>
            <th>@Html.DisplayNameFor(model => model.FechaVencimiento)</th>
            <th>@Html.DisplayNameFor(model => model.Descripcion)</th>
            <th>@Html.DisplayNameFor(model => model.Estado)</th>
            <th>@Html.DisplayNameFor(model => model.Categoria)</th>
            <th>@Html.DisplayNameFor(model => model.Estante)</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                <td>@Html.DisplayFor(modelItem => item.Precio)</td>
                <td>
                    @if (item.BajoStock)
                    {
                        <span class="badge bg-danger">@item.Stock ⚠️</span>
                    }
                    else
                    {
                        @item.Stock
                    }
                </td>
                <td>
                    @if (item.EstaVencido)
                    {
                        <span class="badge bg-danger">@item.FechaVencimiento.ToShortDateString() Vencido</span>
                    }
                    else if (item.PorVencer30)
                    {
                        <span class="badge bg-warning text-dark">@item.FechaVencimiento.ToShortDateString() Por vencer</span>
                    }
                    else
                    {
                        @item.FechaVencimiento.ToShortDateString()
                    }
                </td>
                <td>@Html.DisplayFor(modelItem => item.Descripcion)</td>
                <td>
                    @if (item.Estado)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </td>
                <td>@Html.DisplayFor(modelItem => item.Categoria!.Nombre)</td>
                <td>@Html.DisplayFor(modelItem => item.Estante!.Nombre)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Ver</a>
                    @if (User.IsInRole("Administrador") || User.IsInRole("Farmaceutico"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                    }
                    @if (User.IsInRole("Administrador"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>