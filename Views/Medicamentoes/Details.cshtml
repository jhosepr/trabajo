@model Farmacia.Models.Medicamento

@{
    ViewData["Title"] = "Detalles de Medicamento";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-lg border border-info rounded-4 bg-dark text-light overflow-hidden">
                <div class="card-header bg-info text-dark py-4 text-center border-bottom border-info">
                    <i class="fas fa-info-circle fa-3x mb-2 shadow-sm rounded-circle p-1" style="background: rgba(0,0,0,0.1);"></i>
                    <h3 class="mb-0 fw-bold">Detalles de Medicamento</h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    
                    <div class="bg-black bg-opacity-50 p-4 rounded-3 border border-secondary mb-5 shadow-sm">
                        <h4 class="text-info fw-bold text-center mb-4 border-bottom border-secondary pb-3">@Html.DisplayFor(model => model.Nombre)</h4>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="row mb-3">
                                    <div class="col-5 text-end text-light opacity-75 fw-bold text-uppercase small">Precio:</div>
                                    <div class="col-7 text-start fw-bold text-success"><i class="fas fa-dollar-sign me-1"></i>@Html.DisplayFor(model => model.Precio)</div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-5 text-end text-light opacity-75 fw-bold text-uppercase small">Stock:</div>
                                    <div class="col-7 text-start"><span class="badge bg-secondary border border-secondary text-white px-2 py-1">@Html.DisplayFor(model => model.Stock) unid.</span></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="row mb-3">
                                    <div class="col-5 text-end text-light opacity-75 fw-bold text-uppercase small">Vencimiento:</div>
                                    <div class="col-7 text-start">
                                        <i class="fas fa-calendar-alt me-1 text-warning"></i>@Model?.FechaVencimiento.ToShortDateString()
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-5 text-end text-light opacity-75 fw-bold text-uppercase small">Estado:</div>
                                    <div class="col-7 text-start">
                                        @if(Model?.Estado == true){
                                            <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Activo</span>
                                        } else {
                                            <span class="badge bg-danger"><i class="fas fa-times-circle me-1"></i>Inactivo</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row mt-3 border-top border-secondary pt-3">
                            <div class="col-5 col-md-3 text-end text-light opacity-75 fw-bold text-uppercase small">Registrado en:</div>
                            <div class="col-7 col-md-9 text-start">
                                <span class="badge bg-primary me-2"><i class="fas fa-tags me-1"></i>@Html.DisplayFor(model => model.Categoria!.Nombre)</span>
                                <span class="badge bg-info text-dark"><i class="fas fa-map-marker-alt me-1"></i>@Html.DisplayFor(model => model.Estante!.Nombre)</span>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-5 col-md-3 text-end text-light opacity-75 fw-bold text-uppercase small">Descripción:</div>
                            <div class="col-7 col-md-9 text-start">@Html.DisplayFor(model => model.Descripcion)</div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-bold text-light">
                            <i class="fas fa-arrow-left me-1"></i> Volver al Listado
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning rounded-pill px-4 fw-bold text-dark shadow-sm">
                            <i class="fas fa-edit me-1"></i> Editar Medicamento
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
