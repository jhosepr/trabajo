@model IEnumerable<Farmacia.Models.Estante>
@{
    ViewData["Title"] = "Gestión de Estantes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🛋️ Estantes / Ubicaciones</h2>
    @if (User.IsInRole("Administrador"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nuevo Estante
        </a>
    }
</div>

<div class="card shadow">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3">@Html.DisplayNameFor(model => model.Nombre)</th>
                    <th>@Html.DisplayNameFor(model => model.Ubicacion)</th>
                    <th>@Html.DisplayNameFor(model => model.Descripcion)</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3 fw-bold">@Html.DisplayFor(modelItem => item.Nombre)</td>
                        <td>
                            <span class="badge bg-light text-dark border">
                                <i class="fas fa-map-marker-alt text-danger me-1"></i>
                                @Html.DisplayFor(modelItem => item.Ubicacion)
                            </span>
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.Descripcion)</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">
                                <i class="fas fa-eye"></i> Ver
                            </a>
                            @if (User.IsInRole("Administrador"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i> Editar
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Eliminar
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
