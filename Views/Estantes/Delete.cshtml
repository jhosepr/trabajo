@model Farmacia.Models.Estante

@{
    ViewData["Title"] = "Eliminar Estante";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border border-danger rounded-4 bg-dark text-light overflow-hidden">
                <div class="card-header bg-danger text-white py-4 text-center border-bottom border-danger">
                    <i class="fas fa-exclamation-triangle fa-3x mb-2 shadow-sm rounded-circle p-1"></i>
                    <h3 class="mb-0 fw-bold">Eliminar Estante</h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <h5 class="text-center text-light mb-4 fw-normal">
                        ¿Estás seguro de que deseas eliminar este estante de forma permanente? <strong class="text-danger">Esta acción no se puede deshacer.</strong>
                    </h5>
                    
                    <div class="bg-black bg-opacity-50 p-4 rounded-3 border border-secondary mb-4 shadow-sm">
                        <h4 class="text-danger fw-bold text-center mb-4">@Html.DisplayFor(model => model.Nombre)</h4>
                        
                        <div class="row mb-2">
                            <div class="col-4 text-end text-light opacity-75 fw-bold">Ubicación:</div>
                            <div class="col-8 text-start">@Html.DisplayFor(model => model.Ubicacion)</div>
                        </div>
                        <div class="row mb-0">
                            <div class="col-4 text-end text-light opacity-75 fw-bold">Descripción:</div>
                            <div class="col-8 text-start">@Html.DisplayFor(model => model.Descripcion)</div>
                        </div>
                    </div>

                    <form asp-action="Delete" class="d-flex justify-content-between align-items-center mt-2">
                        <input type="hidden" asp-for="Id" />
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold text-light">
                            <i class="fas fa-arrow-left me-1"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-danger px-4 fw-bold shadow-sm">
                            <i class="fas fa-trash-alt me-1"></i> Eliminar
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
